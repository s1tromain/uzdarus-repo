// 🔐 БЕЗОПАСНЫЕ FIRESTORE RULES
// Храни в: /firestore.rules
// Деплой: firebase deploy --only firestore:rules

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===== USERS COLLECTION =====
    match /users/{userId} {
      // ✅ Каждый пользователь видит только свой профиль
      allow read: if request.auth != null && request.auth.uid == userId;
      
      // ✅ Регистрация: сервер создает с admin SDK
      allow create: if request.auth != null && request.auth.uid == userId;
      
      // ✅ Обновление: только свой профиль
      allow update: if request.auth != null && request.auth.uid == userId;
      
      // ✅ Удаление: только свой профиль
      allow delete: if request.auth != null && request.auth.uid == userId;
    }
    
    // ===== LESSONS COLLECTION =====
    match /lessons/{lessonId} {
      // ✅ Видеть только свои уроки
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      
      // ✅ Создавать (сервер добавляет userId)
      allow create: if request.auth != null && 
                       request.resource.data.userId == request.auth.uid;
      
      // ✅ Обновлять только свои
      allow update: if request.auth != null && 
                       resource.data.userId == request.auth.uid;
      
      // ✅ Удалять только свои
      allow delete: if request.auth != null && 
                       resource.data.userId == request.auth.uid;
    }
    
    // ===== PUBLIC DATA (Если нужны общие ресурсы) =====
    match /courses/{courseId} {
      // ✅ Курсы видят все аутентифицированные пользователи
      allow read: if request.auth != null;
      
      // ✅ Создавать/редактировать только администраторы
      allow write: if request.auth != null && 
                      get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    // ===== ACTIVITY LOGS (для админов) =====
    match /activityLogs/{logId} {
      // ✅ Только администраторы видят логи
      allow read: if request.auth != null && 
                     get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
      
      // ✅ Сервер записывает логи
      allow create: if request.auth != null;
      
      // ❌ Логи неизменяемые
      allow update, delete: if false;
    }
    
    // ===== Default: Запреши все остальное =====
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
