# 🌐 NGINX REVERSE PROXY CONFIG
# Сохрани в: /etc/nginx/sites-available/default
# Потом: sudo ln -s /etc/nginx/sites-available/default /etc/nginx/sites-enabled/default

# HTTP -> HTTPS редирект
server {
    listen 80;
    server_name твой-домен.com www.твой-домен.com;
    
    location /.well-known/acme-challenge/ {
        root /var/www/certbot;
    }
    
    location / {
        return 301 https://$server_name$request_uri;
    }
}

# HTTPS Server
server {
    listen 443 ssl http2;
    server_name твой-домен.com www.твой-домен.com;

    # SSL certificates (Certbot)
    ssl_certificate /etc/letsencrypt/live/твой-домен.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/твой-домен.com/privkey.pem;

    # Security headers
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers HIGH:!aNULL:!MD5;
    ssl_prefer_server_ciphers on;
    ssl_session_cache shared:SSL:10m;
    ssl_session_timeout 10m;

    # Security headers
    add_header Strict-Transport-Security "max-age=63072000; includeSubDomains; preload" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header X-XSS-Protection "1; mode=block" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;

    # Логи
    access_log /var/log/nginx/access.log;
    error_log /var/log/nginx/error.log;

    # ========== ФРОНТЕНД (статические файлы) ==========
    location / {
        root /var/www/frontend;
        index index.html;
        
        # SPA: все маршруты -> index.html
        try_files $uri $uri/ /index.html;
        
        # Кэш для статических файлов
        location ~* \.(js|css|png|jpg|jpeg|gif|ico|svg|woff|woff2)$ {
            expires 1y;
            add_header Cache-Control "public, immutable";
        }
    }

    # ========== API (обратный прокси на Node.js) ==========
    location /api/ {
        proxy_pass http://localhost:3000;
        proxy_http_version 1.1;
        
        # Headers для проксирования
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Host $host;

        # Таймауты
        proxy_connect_timeout 60s;
        proxy_send_timeout 60s;
        proxy_read_timeout 60s;
    }

    # ========== HEALTH CHECK ==========
    location /health {
        proxy_pass http://localhost:3000;
        proxy_set_header Host $host;
        access_log off;
    }
}
